# ================================================
# congmap.org server configuration template
# Copy this file to .env and fill in real values
# ================================================

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=congmap
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=congmap

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# JWT
JWT_SECRET=replace_with_64_random_chars_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_64_random_chars
JWT_REFRESH_EXPIRES_IN=30d

# bcrypt
BCRYPT_ROUNDS=12

# Expo Push Notifications (filled later when push module is added)
EXPO_ACCESS_TOKEN=

# CORS (comma-separated list for production; * for dev)
CORS_ORIGIN=*
